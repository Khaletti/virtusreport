# ─── Sanity CMS ───────────────────────────────────────────────────────────────
# Get these from sanity.io → your project → API → Tokens
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# Create a token with "Viewer" role for public reads
SANITY_API_READ_TOKEN=your_read_token_here

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# For server-side operations (keep secret)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── DeepL Translation ────────────────────────────────────────────────────────
# Get from deepl.com/pro-api (free tier: 500k chars/month)
DEEPL_API_KEY=your_deepl_api_key_here

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://virtusreport.com
